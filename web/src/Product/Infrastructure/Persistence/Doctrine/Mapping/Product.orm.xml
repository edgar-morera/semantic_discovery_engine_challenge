<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Product\Domain\Model\Product" table="products">

        <id name="productId" type="product_id" column="id">
            <generator strategy="NONE"/>
        </id>

        <field name="productName" type="product_name" column="name" length="255" nullable="false"/>

        <field name="semanticDescription" type="product_semantic_description" column="semantic_description" nullable="false"/>

    </entity>

</doctrine-mapping>
